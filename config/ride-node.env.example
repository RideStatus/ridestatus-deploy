# =============================================================================
# RideStatus — Ride Edge Node Environment Variables
# =============================================================================
# Copy to ride-node.env and fill in values. NEVER commit ride-node.env.
# =============================================================================

# --- Ride Identity ---
RIDE_NAME=Goliath
RIDE_DISPLAY_NAME="Goliath"

# --- PLC Connection ---
PLC_IP=10.250.1.50
PLC_SLOT=0
PLC_PROTOCOL=enip                    # enip | pccc | netdde
# For NetDDE only:
# NETDDE_HOST=10.250.1.51
# NETDDE_SHARE=RideShare
# NETDDE_PORT=4096

# --- PLC Tag Names (EtherNet/IP tag names or PCCC addresses) ---
TAG_MODE=ProgramMode
TAG_FAULT=FaultCode
TAG_FAULT_MESSAGE=FaultMessage
TAG_FAULT_TS=FaultTimestamp
TAG_CYCLE_COUNT=TotalCycles
TAG_CYCLE_TIME=LastCycleTime
TAG_STATUS_MESSAGE=StatusMessage
TAG_RTC=SystemTime

# --- Polling ---
POLL_INTERVAL_MS=1000
OFFLINE_TIMEOUT_S=300

# --- Aggregation Server ---
SERVER_HOST=10.250.0.10
SERVER_PORT=3100
SERVER_API_KEY=changeme
PUSH_INTERVAL_S=3

# --- Local SQLite ---
SQLITE_PATH=/opt/ridestatus/ride/data/ride.db

# --- Node-RED ---
NODE_RED_PORT=1880
NODE_RED_ADMIN_PASSWORD=changeme

# --- Dev / Testing ---
# MOCK_PLC=true
# LOG_LEVEL=debug
