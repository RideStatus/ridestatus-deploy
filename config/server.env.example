# =============================================================================
# RideStatus — Aggregation Server Environment Variables
# =============================================================================
# Copy to server.env and fill in values. NEVER commit server.env.
# =============================================================================

# --- Park Identity ---
PARK_NAME="Six Flags Great America"
PARK_TIMEZONE="America/Chicago"

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ridestatus
POSTGRES_USER=ridestatus
POSTGRES_PASS=changeme

# --- Aggregation API ---
API_PORT=3100
API_KEY=changeme

# --- Main Board UI ---
UI_PORT=3000

# --- Weather (WeatherAPI.com) ---
WEATHER_API_KEY=your_weatherapi_key_here
WEATHER_ZIP=60031
WEATHER_POLL_INTERVAL_S=60

# --- Fault Alerting ---
ALERT_EMAIL=ops@yourpark.com
ALERT_SMS=8005551234@vtext.com
SMTP_HOST=smtp.yourpark.com
SMTP_PORT=587
SMTP_USER=alerts@yourpark.com
SMTP_PASS=changeme

# --- Thresholds ---
OFFLINE_TIMEOUT_S=300
RTC_DRIFT_WARN_S=900
