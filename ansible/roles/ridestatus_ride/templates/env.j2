# =============================================================================
# RideStatus Edge Node — Environment
# Managed by Ansible — do not edit manually.
# Last written: {{ ansible_date_time.iso8601 }}
# Host: {{ inventory_hostname }}  Ride: {{ ride_name }}
# =============================================================================

# Ride identity
RIDE_NAME={{ ride_name }}

# PLC connection
PLC_PROTOCOL={{ plc_protocol }}
PLC_IP={{ plc_ip }}
PLC_SLOT={{ plc_slot | default(0) }}

# NetDDE (only used if PLC_PROTOCOL=netdde)
NETDDE_HOST={{ netdde_host | default('') }}
NETDDE_SHARE={{ netdde_share | default('') }}

# PLC tag names
TAG_MODE={{ tag_mode }}
TAG_FAULT={{ tag_fault }}
TAG_FAULT_MESSAGE={{ tag_fault_message }}
TAG_FAULT_TS={{ tag_fault_ts }}
TAG_CYCLE_COUNT={{ tag_cycle_count }}
TAG_CYCLE_TIME={{ tag_cycle_time }}
TAG_STATUS_MESSAGE={{ tag_status_message }}
TAG_RTC={{ tag_rtc }}

# Network interfaces
RIDESTATUS_NIC_INTERFACE={{ ridestatus_nic_interface }}
RIDE_NIC_INTERFACE={{ ride_nic_interface }}

# Aggregation server
SERVER_HOST={{ ridestatus_server_host }}
SERVER_PORT={{ ridestatus_server_port }}
SERVER_API_KEY={{ ridestatus_api_key }}
SERVER_BOOTSTRAP_TOKEN={{ existing_bootstrap_token | default('') }}

# Timing
POLL_INTERVAL_MS={{ poll_interval_ms }}
PUSH_INTERVAL_S={{ push_interval_s }}
OFFLINE_TIMEOUT_S={{ offline_timeout_s }}
PUSH_MAX_QUEUE={{ push_max_queue }}

# SQLite
SQLITE_PATH={{ rs_data }}/ride.db

# Node-RED
NODE_RED_PORT={{ node_red_port }}

# Logging
LOG_LEVEL=info
LOG_FILE=logs/poller.log

# Development only — set in host_vars if needed
MOCK_PLC=false
